{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "FlowSpace",
  "version": "0.1.0",
  "identifier": "com.flowspace.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowSpace",
        "width": 1100,
        "height": 680,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "visible": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "An immersive productivity companion driven by flow energy.",
    "longDescription": "FlowSpace is an immersive desktop productivity tool that turns typing momentum into responsive visuals and adaptive ambient audio.",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./Entitlements.macOS.plist"
    }
  }
}
